{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meridian.local/schemas/agents/v1/final-decision.schema.json",
  "title": "Supervisor final decision v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocolVersion",
    "runId",
    "workPackageId",
    "baseCommit",
    "candidateCommit",
    "actor",
    "authorizedCostCeilingUsd",
    "status",
    "requirementsEvaluated",
    "findings",
    "evidencePaths",
    "commandsExecuted",
    "testResults",
    "nextRequestedActor",
    "humanGateRequired",
    "estimatedCostUsd",
    "repairCycles",
    "mergeAuthorized"
  ],
  "properties": {
    "protocolVersion": { "const": "1.0.0" },
    "runId": { "type": "string" },
    "workPackageId": { "type": "string" },
    "baseCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "candidateCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "actor": { "const": "supervisor" },
    "authorizedCostCeilingUsd": { "type": "number", "minimum": 0 },
    "status": {
      "enum": ["approved", "blocked", "human_gate_required", "failed"]
    },
    "requirementsEvaluated": { "type": "array", "items": { "type": "string" } },
    "findings": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/finding" }
    },
    "evidencePaths": { "type": "array", "items": { "type": "string" } },
    "commandsExecuted": { "type": "array", "items": { "type": "string" } },
    "testResults": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/testResult" }
    },
    "nextRequestedActor": { "enum": ["human", "none"] },
    "humanGateRequired": { "type": "boolean" },
    "estimatedCostUsd": { "type": "number", "minimum": 0 },
    "repairCycles": { "type": "integer", "minimum": 0, "maximum": 4 },
    "mergeAuthorized": { "const": false }
  }
}
