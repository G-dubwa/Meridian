{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": true,
    "jsx": "react-jsx",
    "outDir": ".types",
    "plugins": [{ "name": "next" }],
    "paths": {
      "@meridian/api-contracts": ["../../packages/api-contracts/dist/index"],
      "@meridian/application": ["../../packages/application/dist/index"],
      "@meridian/domain": ["../../packages/domain/dist/index"],
      "@meridian/infrastructure-auth": [
        "../../packages/infrastructure-auth/dist/index"
      ],
      "@meridian/infrastructure-db": [
        "../../packages/infrastructure-db/dist/index"
      ],
      "@meridian/infrastructure-ms-graph": [
        "../../packages/infrastructure-ms-graph/dist/index"
      ],
      "@meridian/infrastructure-models": [
        "../../packages/infrastructure-models/dist/index"
      ],
      "@meridian/knowledge": ["../../packages/knowledge/dist/index"],
      "@meridian/prompts": ["../../packages/prompts/dist/index"],
      "@meridian/retrieval": ["../../packages/retrieval/dist/index"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx"
  ],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/domain" },
    { "path": "../../packages/application" },
    { "path": "../../packages/api-contracts" },
    { "path": "../../packages/infrastructure-auth" },
    { "path": "../../packages/infrastructure-db" },
    { "path": "../../packages/infrastructure-ms-graph" },
    { "path": "../../packages/infrastructure-models" },
    { "path": "../../packages/knowledge" },
    { "path": "../../packages/prompts" },
    { "path": "../../packages/retrieval" }
  ]
}
